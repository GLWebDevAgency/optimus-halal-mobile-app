{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_URL": "https://api-preview.naqiy.app",
        "EXPO_PUBLIC_SENTRY_DSN": "$SENTRY_DSN",
        "EXPO_PUBLIC_POSTHOG_KEY": "$POSTHOG_API_KEY",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_URL": "https://api.naqiy.app",
        "EXPO_PUBLIC_SENTRY_DSN": "$SENTRY_DSN",
        "EXPO_PUBLIC_POSTHOG_KEY": "$POSTHOG_API_KEY"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ghassenelimame@gmail.com",
        "ascAppId": "6761675347",
        "appleTeamId": "9NS97W7637"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
