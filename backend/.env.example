# Database (direct connection)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/naqiy
# Database (via PgBouncer — docker compose up pgbouncer -d)
# DATABASE_URL=postgresql://postgres:postgres@localhost:6432/naqiy

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3000
NODE_ENV=development

# Email (Brevo)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@naqiy.app
BREVO_SENDER_NAME=Naqiy

# Expo Push
EXPO_ACCESS_TOKEN=your-expo-access-token

# OpenFoodFacts
OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v2

# CORS
CORS_ORIGINS=*

# Sentry (optional)
# SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production

# AI Ingredient Extraction (provider-agnostic: gemini | openai | anthropic)
AI_EXTRACT_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Cloudflare R2 (Image hosting)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=naqiy
R2_PUBLIC_DOMAIN=pub-xxx.r2.dev

# Internal cron endpoints (min 32 chars — used by GitHub Actions cron workflows)
# CRON_SECRET=your-cron-secret-min-32-chars-long

# Google Places API (manual enrichment only — NOT called on deploy)
# GOOGLE_PLACES_API_KEY=your-google-places-api-key

# App Version Control (used by GET /app-config)
MIN_APP_VERSION=1.0.0
LATEST_APP_VERSION=1.0.0
# FORCE_APP_UPDATE=false
# APP_MAINTENANCE=false
# APP_MESSAGE=
# APP_STORE_URL=https://apps.apple.com/app/naqiy/id0000000000
# PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.naqiy.app

# Test database (local development — run scripts/setup-test-db.sh)
# DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5433/naqiy_test
