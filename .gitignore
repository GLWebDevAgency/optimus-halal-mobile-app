# ══════════════════════════════════════════════════════════════
# Naqiy — Root .gitignore (monorepo)
# ══════════════════════════════════════════════════════════════

# ── OS Generated ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDEs & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-project
*.sublime-workspace

# ── Node / pnpm ──────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.stylelintcache

# ── Environment & Secrets ────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.p8
*.jks
*.mobileprovision
*.keystore
**/credentials.json
*.secret
# Dossiers V2 (scholarly corpus for Halal Engine V2) + substance
# pipeline are tracked. Legacy v1 working directories (abbatage/,
# additifs/) remain ignored as they are superseded by dossiers_v2/.
!docs/naqiy/dossiers-recherches-naqiy/
!docs/naqiy/dossiers-recherches-naqiy/dossiers_v2/
!docs/naqiy/dossiers-recherches-naqiy/dossiers_v2/**
!docs/naqiy/dossiers-recherches-naqiy/naqiy_substance_pipeline.json
docs/naqiy/dossiers-recherches-naqiy/abbatage/
docs/naqiy/dossiers-recherches-naqiy/additifs/
docs/naqiy/dossiers-recherches-naqiy/.DS_Store

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Build Outputs ────────────────────────────────────────────
dist/
build/
.cache/
*.apk
*.aab
*.ipa
*.app

# ── Android SDK (local install — never commit) ───────────────
build-tools/
platform-tools/
platforms/
licenses/
.knownPackages
cmdline-tools/
emulator/
ndk/
skiaparser/
sources/
system-images/

# ── Expo ─────────────────────────────────────────────────────
.expo/
web-build/
expo-env.d.ts

# ── Metro Bundler ────────────────────────────────────────────
.metro-health-check*

# ── Testing & Coverage ───────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Playwright / E2E ─────────────────────────────────────────
.playwright-mcp/
playwright-report/
test-results/
blob-report/

# ── Debug & Logs ─────────────────────────────────────────────
firebase-debug.log
firestore-debug.log
ui-debug.log
*.log

# ── Sentry ───────────────────────────────────────────────────
.sentryclirc

# ── Temp Screenshots & Images (root level) ───────────────────
/app-test-*.png
/image.png
/screenshots/

# ── Documentation artifacts (generated/planning) ────────────
docs/audits/
docs/plan-final-*/
optimus-halal/docs/

# ── Design mockups & print assets ────────────────────────────
stitch_onboarding_reliable_certifications/
flyer/

# ── Research / personal folders (not source code) ────────────
apps-et-sources-infos-medias/
apps-to-explore/
tools/*
stitch/
stitch.zip
.superpowers/
.claude/worktrees/
.claude/audit-*.md
.vercel
.wrangler/
.env*.local

